# LIS Streamlit Cloud Secrets 範本
# 部署到 Streamlit Cloud 後，在「Settings → Secrets」貼這份內容（去掉 .example）

# ─── LINE Messaging API ───
LINE_CHANNEL_ACCESS_TOKEN = "你的_LINE_token"
LINE_USER_ID = "Ryan 的 LINE userId"

# ─── Google Gemini AI ───
GEMINI_API_KEY = "你的_Gemini_API_key"

# ─── Fugle 即時報價（如用） ───
FUGLE_API_TOKEN = "你的_Fugle_token"

# ─── portfolio.json 雲端版（敏感資料）───
# 方案 A：直接 inline（簡單但欄位多）
# 方案 B：用 GitHub Gist 私密 URL，這裡放 URL
PORTFOLIO_GIST_URL = "https://gist.githubusercontent.com/你的帳號/.../raw/portfolio.json"

# ─── Sylvie 對帳單（如要雲端共識）───
SYLVIE_GIST_URL = "https://gist.githubusercontent.com/.../raw/sylvie_portfolio.json"
